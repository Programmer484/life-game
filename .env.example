# Supabase credentials — S13 wiring reads these via import.meta.env.
# Copy to .env.local and fill in from the Supabase project dashboard.
# NEVER commit real values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Anthropic API key for the goal/reflection coach — SERVER-SIDE ONLY. Read by
# the Vite dev proxy / deploy platform (no VITE_ prefix, never bundled).
ANTHROPIC_API_KEY=
